---
const version = "0.3.0";
---

<section class="hero">
  <div class="container container--wide">
    <div class="hero-badge reveal"><span class="dot"></span> v{version} &mdash; Open Source &middot; MIT</div>
    <h1 class="reveal reveal-delay-1">Run LLMs <em>natively</em><br>on Apple Silicon</h1>
    <p class="hero-sub reveal reveal-delay-2">
      MLX-native inference. <strong>43&ndash;112% faster</strong> than GGUF translation layers. OpenAI-compatible API. 168+ models. Zero config.
    </p>
    <div class="hero-actions reveal reveal-delay-3">
      <div class="install-cmd" data-copy="uv tool install ppmlx" role="button" tabindex="0">
        <span class="prompt">$</span><span>uv tool install ppmlx</span>
        <svg class="copy-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
        <span class="tooltip">Copied!</span>
      </div>
      <a href="https://github.com/the-focus-company/ppmlx" class="btn-primary" target="_blank" rel="noopener">
        View on GitHub
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative; z-index: 1;
    padding-top: clamp(120px, 18vw, 180px); padding-bottom: var(--section-gap);
  }
  .hero::before {
    content: ''; position: absolute; top: -20%; left: 50%; transform: translateX(-50%);
    width: 800px; height: 600px;
    background: radial-gradient(ellipse, var(--accent-glow) 0%, transparent 70%);
    pointer-events: none; z-index: -1;
  }
  .hero { overflow: hidden; }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 6px 14px; border: 1px solid var(--border); border-radius: 100px;
    font-family: var(--font-mono); font-size: 12px; color: var(--text-secondary);
    margin-bottom: 28px; background: var(--bg-surface);
  }
  .dot {
    width: 6px; height: 6px; border-radius: 50%; background: var(--teal);
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(61, 181, 166, 0.4); }
    50% { opacity: 0.7; box-shadow: 0 0 0 6px rgba(61, 181, 166, 0); }
  }
  h1 {
    font-family: var(--font-display); font-weight: 300;
    font-size: clamp(40px, 6vw, 72px); line-height: 1.05;
    letter-spacing: -0.03em; margin-bottom: 20px;
  }
  h1 em { font-style: italic; color: var(--accent-bright); }
  .hero-sub {
    font-size: clamp(16px, 2vw, 19px); color: var(--text-secondary);
    line-height: 1.6; margin-bottom: 40px; font-weight: 300;
  }
  .hero-sub strong { color: var(--text-primary); font-weight: 400; }
  .hero-actions { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
</style>
