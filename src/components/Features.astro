---
const features = [
  { title: "OpenAI Chat API", desc: "Streaming, tools, vision. Drop-in for any SDK \u2014 Python, Node, Go, Rust." },
  { title: "Anthropic Messages API", desc: "Claude Code runs on your local GPU. One command to launch." },
  { title: "Tool Calling", desc: "Function calling in XML and JSON. Powers coding agents like Codex." },
  { title: "Vision + Embeddings", desc: "Images via mlx-vlm. Vectors for RAG. Same server, same API." },
  { title: "168+ Models", desc: "Llama, Qwen, Mistral, Phi, Gemma, DeepSeek. Curated registry with aliases." },
  { title: "Auto Memory & Logging", desc: "LRU model cache, lazy loading. Every request logged to SQLite." },
];
const compat = ["Claude Code", "Codex", "Open WebUI", "LangChain", "LlamaIndex", "Any OpenAI SDK"];
---

<section class="section" id="features">
  <div class="container container--wide">
    <div class="section-label reveal">What's inside</div>
    <h2 class="section-title reveal reveal-delay-1">Drop-in replacement</h2>
    <p class="section-sub reveal reveal-delay-2" style="margin-bottom:40px">
      OpenAI API, Anthropic Messages API, Responses API. If it speaks HTTP, it works.
    </p>

    <div class="features-grid reveal reveal-delay-3">
      {features.map(({ title, desc }) => (
        <div class="feature-card">
          <h3>{title}</h3>
          <p>{desc}</p>
        </div>
      ))}
    </div>

    <div class="compat-line reveal">
      Works with {compat.map((c, i) => <><span>{c}</span>{i < compat.length - 1 ? " \u00b7 " : ""}</>)}
    </div>
    <div class="roadmap-line reveal">
      Coming soon: Model Garden &middot; ppmlx bench &middot; MCP Server &middot; Speculative Decoding
      &mdash; <a href="https://github.com/the-focus-company/ppmlx/issues" target="_blank" rel="noopener">follow progress &rarr;</a>
    </div>
  </div>
</section>

<style>
  .features-grid {
    display: grid; grid-template-columns: 1fr; gap: 1px;
    background: var(--border); border: 1px solid var(--border);
    border-radius: 12px; overflow: hidden; margin-bottom: 32px;
  }
  @media (min-width: 900px) {
    .features-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .feature-card {
    background: var(--bg-surface); padding: 28px 24px;
    transition: background 0.3s, transform 0.2s; position: relative;
  }
  .feature-card:hover { background: var(--bg-elevated); transform: translateY(-2px); }
  .feature-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: transparent; transition: background 0.3s;
  }
  .feature-card:hover::before { background: linear-gradient(90deg, transparent, var(--accent), transparent); }
  .feature-card h3 { font-family: var(--font-body); font-size: 15px; font-weight: 500; color: var(--text-primary); margin-bottom: 6px; }
  .feature-card p { font-size: 13px; color: var(--text-secondary); line-height: 1.55; font-weight: 300; }

  .compat-line {
    text-align: center; font-family: var(--font-mono); font-size: 13px; color: var(--text-dim);
    padding: 20px 0; margin-bottom: 8px;
  }
  .compat-line span { color: var(--text-secondary); font-weight: 400; }

  .roadmap-line {
    text-align: center; font-family: var(--font-mono); font-size: 12px; color: var(--text-dim);
  }
  .roadmap-line a { color: var(--accent); text-decoration: none; }
  .roadmap-line a:hover { color: var(--accent-bright); }
</style>
